rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to write to files and images
    match /files/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /images/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Allow all authenticated users to read everything else
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}